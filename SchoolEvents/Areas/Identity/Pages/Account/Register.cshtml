@page
@model SchoolEvents.Areas.Identity.Pages.Account.RegisterModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2>Регистрация</h2>

<form method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label">Имейл</label>
        <input asp-for="Input.Email" class="form-control" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Password" class="form-label">Парола</label>
        <input asp-for="Input.Password" type="password" class="form-control" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.ConfirmPassword" class="form-label">Потвърди парола</label>
        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Role" class="form-label">Регистрация като</label>
        <select asp-for="Input.Role" class="form-select">
            <option value="Student">Ученик</option>
            <option value="Teacher">Учител</option>
        </select>
        <span asp-validation-for="Input.Role" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Input.WantsEmailNotifications" class="form-check-input" />
        <label asp-for="Input.WantsEmailNotifications" class="form-check-label">
            Желая да получавам имейл известия за новини и събития
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Регистрация</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}