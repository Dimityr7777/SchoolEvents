@model SchoolEvents.Models.Schoolevent
@{
    ViewData["Title"] = "Редактиране на събитие";
}

<div class="container py-4">
    <div class="hero p-4 p-md-5 mb-4">
        <h1 class="mb-2">Редактиране</h1>
        <p class="text-muted mb-0">@Model.Title</p>
    </div>

    <div class="card p-4">
        <form asp-controller="Admin" asp-action="EditEvent" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Заглавие</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Дата</label>
                    <input asp-for="StartAt"
                           type="date"
                           class="form-control"
                           value="@(Model.StartAt.HasValue? Model.StartAt.Value.ToString("yyyy-MM-dd") : "")" />
                    <span asp-validation-for="StartAt" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Място</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label">Тип</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary" type="submit">Запази</button>
                <a class="btn btn-outline-primary" asp-controller="Admin" asp-action="Events">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}