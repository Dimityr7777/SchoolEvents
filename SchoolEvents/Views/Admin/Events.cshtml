@model List<SchoolEvents.Models.Schoolevent>
@{
    ViewData["Title"] = "Управление на събития";
}

<div class="container py-4">
    <div class="hero p-4 p-md-5 mb-4">
        <h1 class="mb-2">Управление на събития</h1>
        <p class="text-muted mb-0">Изтриване на събития.</p>
    </div>

    @if (TempData["AdminSuccess"] != null)
    {
        <div class="alert alert-info">@TempData["AdminSuccess"]</div>
    }

    <div class="card p-3">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Заглавие</th>
                        <th>Място</th>
                        <th>Тип</th>
                        <th style="width:160px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="text-muted">
                                @(e.StartAt.HasValue? e.StartAt.Value.ToString("dd.MM.yyyy") : "Без дата")
                            </td>
                            <td>@e.Title</td>
                            <td>@e.Location</td>
                            <td>@e.Type</td>
                            <td>
                                <form asp-controller="Admin"
                                      asp-action="DeleteEvent"
                                      asp-route-id="@e.Id"
                                      method="post"
                                      class="m-0"
                                      onsubmit="return confirm('Сигурен ли си, че искаш да изтриеш това събитие?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        Изтрий
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>