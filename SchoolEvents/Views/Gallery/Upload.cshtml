@{
    ViewData["Title"] = "Качи снимка";
}

<div class="container py-4">
    <div class="hero p-4 p-md-5 mb-4">
        <h1 class="mb-2">Качи снимка</h1>
        <p class="text-muted mb-0">Само администратор може да качва снимки.</p>
    </div>

    <div class="card p-4">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Заглавие</label>
                <input name="title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Описание (по избор)</label>
                <textarea name="description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Албум</label>
                <select name="albumId" class="form-select" required>
                    <option value="">-- Избери албум --</option>
                    @foreach (var a in (IEnumerable<SchoolEvents.Models.GalleryAlbum>)ViewBag.Albums)
                    {
                        <option value="@a.Id">@a.Title</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Снимка</label>
                <input type="file" name="file" class="form-control" accept="image/*" />
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Качи</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
            </div>
        </form>
    </div>
</div>     