@{
    ViewData["Title"] = "Контакти";
}

<div class="container py-4">

    <div class="hero p-4 p-md-5 mb-4 text-center">
        <h1 class="mb-2">Свържете се с нас</h1>
        <p class="text-muted mb-0">
            Изпратете съобщение чрез формата по-долу.
        </p>
    </div>

    @if (TempData["ContactSuccess"] != null)
    {
        <div class="alert alert-info text-center">
            @TempData["ContactSuccess"]
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="card p-4">
                <h4 class="mb-3 text-center">Форма за контакт</h4>

                <form method="post" asp-controller="Home" asp-action="Contact">

                    <div class="mb-3">
                        <label class="form-label">Име *</label>
                        <input name="name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Е-мейл *</label>
                        <input name="email" type="email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Тема *</label>
                        <input name="subject" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Съобщение *</label>
                        <textarea name="message" class="form-control" rows="6" required></textarea>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-primary" type="submit">
                            Изпрати съобщение
                        </button>
                    </div>

                </form>
            </div>

        </div>
    </div>

</div>

