@model SchoolEvents.Models.Schoolevent

@{
    ViewData["Title"] = "Детайли";
}

<div class="container py-4">

    <div class="card event-details-card p-3 p-md-4">

        <div class="row g-4 align-items-center">

            <div class="col-md-5">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath"
                         alt="@Model.Title"
                         class="event-details-image" />
                }
                else
                {
                    <div class="event-details-image d-flex align-items-center justify-content-center">
                        <span class="text-muted">Няма снимка</span>
                    </div>
                }
            </div>

            <div class="col-md-7">

                <h2 class="fw-bold mb-3">@Model.Title</h2>

                @if (Model.StartAt.HasValue)
                {
                    <div class="event-info mb-2">
                        <strong>Дата:</strong> @Model.StartAt.Value.ToString("dd.MM.yyyy")
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Location))
                {
                    <div class="event-info mb-2">
                        <strong>Място:</strong> @Model.Location
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Type))
                {
                    <div class="event-info mb-3">
                        <strong>Тип:</strong> @Model.Type
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="event-description mb-4">
                        @Model.Description
                    </div>
                }

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Назад
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                            Редактирай
                        </a>
                    }
                </div>

            </div>

        </div>

    </div>

</div>