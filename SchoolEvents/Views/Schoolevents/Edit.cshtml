@model SchoolEvents.Models.Schoolevent

@{
    ViewData["Title"] = "Редакция";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Редакция на събитие</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="card shadow-sm event-form-card">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagePath" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Заглавие</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="StartAt" class="form-label fw-semibold">Дата</label>
                    <input asp-for="StartAt"
                           class="form-control"
                           type="date"
                           value="@(Model.StartAt.HasValue? Model.StartAt.Value.ToString("yyyy-MM-dd") : "")" />
                    <span asp-validation-for="StartAt" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Location" class="form-label fw-semibold">Място</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Type" class="form-label fw-semibold">Категория / Тип</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger small"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
            {
                <div class="mt-4">
                    <label class="form-label fw-semibold d-block">Текуща снимка</label>
                    <img src="@Model.ImagePath"
                         alt="@Model.Title"
                         class="img-fluid rounded-4 shadow-sm"
                         style="max-width: 260px; max-height: 200px; object-fit: cover;" />
                </div>
            }

            <div class="mt-3">
                <label asp-for="ImageFile" class="form-label fw-semibold">Нова снимка</label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Запази промените</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}